@prefix hpo: <https://example.org/heritage-pathology-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/heritage-pathology-ontology> a owl:Ontology .

#################################################################
# Classes
#################################################################

hpo:Observation a owl:Class .

hpo:VisibilityContext a owl:Class ;
    rdfs:label "Contexte de visibilité"@fr .

hpo:ElementCategory a owl:Class ;
    rdfs:label "Type d'éléments"@fr .

hpo:ElementFunction a owl:Class ;
    rdfs:label "Utilité"@fr .

hpo:Component a owl:Class ;
    rdfs:label "Nom"@fr .

hpo:Material a owl:Class ;
    rdfs:label "Matériau"@fr .

hpo:Pathology a owl:Class ;
    rdfs:label "Pathologie"@fr .

hpo:Cause a owl:Class ;
    rdfs:label "Cause"@fr .

hpo:ClassificationLevel a owl:Class ;
    rdfs:label "Niveau de classification"@fr .

#################################################################
# Datatype properties
#################################################################

hpo:workCompletionDelayYears a owl:DatatypeProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range xsd:integer ;
    rdfs:label "Réalisation des travaux"@fr ;
    rdfs:comment "Délai de réalisation des travaux, exprimé en années."@fr .

hpo:controlVisitDelayYears a owl:DatatypeProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range xsd:integer ;
    rdfs:label "Visite de contrôle"@fr ;
    rdfs:comment "Délai avant visite de contrôle, exprimé en années."@fr .

hpo:additionalNotes a owl:DatatypeProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range xsd:string ;
    rdfs:label "Observations libres"@fr ;
    rdfs:comment "Notes libres ou remarques complémentaires associées à l'observation."@fr .

hpo:measurableDataText a owl:DatatypeProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range xsd:string ;
    rdfs:label "Donnée mesurable"@fr .

hpo:remediationText a owl:DatatypeProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range xsd:string ;
    rdfs:label "Remédiation"@fr .

hpo:attachmentUrl a owl:DatatypeProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range xsd:anyURI ;
    rdfs:label "Pièce jointe"@fr .

#################################################################
# Object properties
#################################################################

hpo:hasVisibilityContext a owl:ObjectProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range hpo:VisibilityContext ;
    rdfs:label "où est-ce visible ?"@fr .

hpo:hasElementCategory a owl:ObjectProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range hpo:ElementCategory ;
    rdfs:label "quel type d'éléments ?"@fr .

hpo:hasMaterial a owl:ObjectProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range hpo:Material ;
    rdfs:label "matériau"@fr .

hpo:allowedInVisibilityContext a owl:ObjectProperty ;
    rdfs:domain hpo:ElementCategory ;
    rdfs:range hpo:VisibilityContext ;
    rdfs:label "autorisé dans le contexte de visibilité"@fr .

hpo:hasElementFunction a owl:ObjectProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range hpo:ElementFunction ;
    rdfs:label "utilité"@fr .

hpo:allowedForElementCategory a owl:ObjectProperty ;
    rdfs:domain hpo:ElementFunction ;
    rdfs:range hpo:ElementCategory ;
    rdfs:label "autorisé pour le type d'éléments"@fr .

hpo:allowedForMaterial a owl:ObjectProperty ;
    rdfs:domain hpo:Component ;
    rdfs:range hpo:Material ;
    rdfs:label "autorisé pour le matériau"@fr .

hpo:allowedForElementFunction a owl:ObjectProperty ;
    rdfs:domain hpo:Material ;
    rdfs:range hpo:ElementFunction ;
    rdfs:label "autorisé pour l'utilité"@fr .

hpo:concernsComponent a owl:ObjectProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range hpo:Component ;
    rdfs:label "nom"@fr .

hpo:hasPathology a owl:ObjectProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range hpo:Pathology ;
    rdfs:label "pathologie"@fr .

hpo:hasCause a owl:ObjectProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range hpo:Cause ;
    rdfs:label "cause"@fr .

# Classifications

hpo:hasStructureClassification a owl:ObjectProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range hpo:ClassificationLevel ;
    rdfs:label "Structure"@fr .

hpo:hasUserClassification a owl:ObjectProperty ;
    rdfs:domain hpo:Observation ;
    rdfs:range hpo:ClassificationLevel ;
    rdfs:label "Usagers"@fr .

# Component constraint properties

hpo:componentAllowedForElementFunction a owl:ObjectProperty ;
    rdfs:domain hpo:Component ;
    rdfs:range hpo:ElementFunction ;
    rdfs:label "composant autorisé pour l'utilité"@fr .

hpo:componentAllowedForMaterial a owl:ObjectProperty ;
    rdfs:domain hpo:Component ;
    rdfs:range hpo:Material ;
    rdfs:label "composant autorisé pour le matériau"@fr .

# Pathology constraint properties

hpo:pathologyAllowedForElementFunction a owl:ObjectProperty ;
    rdfs:domain hpo:Pathology ;
    rdfs:range hpo:ElementFunction ;
    rdfs:label "pathologie autorisée pour l'utilité"@fr .

hpo:pathologyAllowedForMaterial a owl:ObjectProperty ;
    rdfs:domain hpo:Pathology ;
    rdfs:range hpo:Material ;
    rdfs:label "pathologie autorisée pour le matériau"@fr .


# Cause constraint properties

hpo:causeAllowedForPathology a owl:ObjectProperty ;
    rdfs:domain hpo:Cause ;
    rdfs:range hpo:Pathology ;
    rdfs:label "cause autorisée pour la pathologie"@fr .@prefix hpo: <https://example.org/heritage-pathology-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Visibility contexts
#################################################################

hpo:Interieur a hpo:VisibilityContext ;
    rdfs:label "Intérieur"@fr .

hpo:Exterieur a hpo:VisibilityContext ;
    rdfs:label "Extérieur"@fr .

hpo:Toiture a hpo:VisibilityContext ;
    rdfs:label "Toiture"@fr .

hpo:Sols a hpo:VisibilityContext ;
    rdfs:label "Sols"@fr .

#################################################################
# Element categories
#################################################################

hpo:ElementNonStructurel a hpo:ElementCategory ;
    rdfs:label "Élément non structurel"@fr ;
    hpo:allowedInVisibilityContext hpo:Interieur .

hpo:ElementAcces a hpo:ElementCategory ;
    rdfs:label "Élément d'accès"@fr ;
    hpo:allowedInVisibilityContext hpo:Interieur .

hpo:ElementStructurel a hpo:ElementCategory ;
    rdfs:label "Élément structurel"@fr ;
    hpo:allowedInVisibilityContext hpo:Interieur .

hpo:Facade a hpo:ElementCategory ;
    rdfs:label "Façade"@fr ;
    hpo:allowedInVisibilityContext hpo:Exterieur .

hpo:ElevationExterieure a hpo:ElementCategory ;
    rdfs:label "Élévation extérieure"@fr ;
    hpo:allowedInVisibilityContext hpo:Exterieur .

hpo:Charpente a hpo:ElementCategory ;
    rdfs:label "Charpente"@fr ;
    hpo:allowedInVisibilityContext hpo:Toiture .

hpo:Couverture a hpo:ElementCategory ;
    rdfs:label "Couverture"@fr ;
    hpo:allowedInVisibilityContext hpo:Toiture .

hpo:Zinguerie a hpo:ElementCategory ;
    rdfs:label "Zinguerie"@fr ;
    hpo:allowedInVisibilityContext hpo:Toiture .

hpo:AutreElementToiture a hpo:ElementCategory ;
    rdfs:label "Autre"@fr ;
    hpo:allowedInVisibilityContext hpo:Toiture .

hpo:VRD a hpo:ElementCategory ;
    rdfs:label "VRD"@fr ;
    rdfs:comment "Voirie et réseaux divers."@fr ;
    hpo:allowedInVisibilityContext hpo:Sols .

hpo:StructureSol a hpo:ElementCategory ;
    rdfs:label "Structure"@fr ;
    hpo:allowedInVisibilityContext hpo:Sols .

#################################################################
# Element functions / Utilité
#################################################################

hpo:RevetementMural a hpo:ElementFunction ;
    rdfs:label "Revêtement mural"@fr ;
    hpo:allowedForElementCategory hpo:ElementNonStructurel .

hpo:Cheminee a hpo:ElementFunction ;
    rdfs:label "Cheminée"@fr ;
    hpo:allowedForElementCategory hpo:ElementNonStructurel .

hpo:RevetementPlafond a hpo:ElementFunction ;
    rdfs:label "Revêtement Plafond"@fr ;
    hpo:allowedForElementCategory hpo:ElementNonStructurel .

hpo:Cloison a hpo:ElementFunction ;
    rdfs:label "Cloison"@fr ;
    hpo:allowedForElementCategory hpo:ElementNonStructurel .

hpo:Escalier a hpo:ElementFunction ;
    rdfs:label "Escalier"@fr ;
    hpo:allowedForElementCategory hpo:ElementAcces .

hpo:SolsInterieurs a hpo:ElementFunction ;
    rdfs:label "Sols"@fr ;
    hpo:allowedForElementCategory hpo:ElementAcces .

hpo:ElementDeBaieInterieur a hpo:ElementFunction ;
    rdfs:label "Élément de baie"@fr ;
    hpo:allowedForElementCategory hpo:ElementAcces .

hpo:Vertical a hpo:ElementFunction ;
    rdfs:label "Vertical"@fr ;
    hpo:allowedForElementCategory hpo:ElementStructurel .

hpo:Horizontal a hpo:ElementFunction ;
    rdfs:label "Horizontal"@fr ;
    hpo:allowedForElementCategory hpo:ElementStructurel .

hpo:Enclos a hpo:ElementFunction ;
    rdfs:label "Enclos"@fr ;
    hpo:allowedForElementCategory hpo:ElevationExterieure .

hpo:Amenagements a hpo:ElementFunction ;
    rdfs:label "Aménagements"@fr ;
    hpo:allowedForElementCategory hpo:ElevationExterieure .

hpo:ElementDeParement a hpo:ElementFunction ;
    rdfs:label "Élément de parement"@fr ;
    hpo:allowedForElementCategory hpo:Facade .

hpo:ElementEnSaillie a hpo:ElementFunction ;
    rdfs:label "Élément en saillie"@fr ;
    hpo:allowedForElementCategory hpo:Facade .

hpo:ElementDeBaieExterieur a hpo:ElementFunction ;
    rdfs:label "Élément de baie"@fr ;
    hpo:allowedForElementCategory hpo:Facade .

hpo:Reseaux a hpo:ElementFunction ;
    rdfs:label "Réseaux"@fr ;
    hpo:allowedForElementCategory hpo:VRD .

hpo:SolsVRD a hpo:ElementFunction ;
    rdfs:label "Sols"@fr ;
    hpo:allowedForElementCategory hpo:VRD .

hpo:MurEnterre a hpo:ElementFunction ;
    rdfs:label "Mur enterré"@fr ;
    hpo:allowedForElementCategory hpo:StructureSol .

hpo:Fondation a hpo:ElementFunction ;
    rdfs:label "Fondation"@fr ;
    hpo:allowedForElementCategory hpo:StructureSol .

hpo:ElementStructurelCharpente a hpo:ElementFunction ;
    rdfs:label "Élément structurel"@fr ;
    hpo:allowedForElementCategory hpo:Charpente .

hpo:PieceDeFixationCharpente a hpo:ElementFunction ;
    rdfs:label "Pièce de fixation"@fr ;
    hpo:allowedForElementCategory hpo:Charpente .

hpo:ElementDeFixationCharpente a hpo:ElementFunction ;
    rdfs:label "Élément de fixation"@fr ;
    hpo:allowedForElementCategory hpo:Charpente .

hpo:ElementCouvrant a hpo:ElementFunction ;
    rdfs:label "Élément couvrant"@fr ;
    hpo:allowedForElementCategory hpo:Couverture .

hpo:ElementDeFixationCouverture a hpo:ElementFunction ;
    rdfs:label "Élément de fixation"@fr ;
    hpo:allowedForElementCategory hpo:Couverture .

hpo:ElementEcoulement a hpo:ElementFunction ;
    rdfs:label "Élément d'écoulement"@fr ;
    hpo:allowedForElementCategory hpo:Zinguerie .

hpo:ElementDeFixationZinguerie a hpo:ElementFunction ;
    rdfs:label "Élément de fixation"@fr ;
    hpo:allowedForElementCategory hpo:Zinguerie .

hpo:ElementDeProtectionZinguerie a hpo:ElementFunction ;
    rdfs:label "Élément de protection"@fr ;
    hpo:allowedForElementCategory hpo:Zinguerie .

hpo:ElementMaconneToiture a hpo:ElementFunction ;
    rdfs:label "Élément maçonné"@fr ;
    hpo:allowedForElementCategory hpo:AutreElementToiture .

hpo:ElementMenuiserieToiture a hpo:ElementFunction ;
    rdfs:label "Élément de menuiserie"@fr ;
    hpo:allowedForElementCategory hpo:AutreElementToiture .

hpo:ElementSerrurerieToiture a hpo:ElementFunction ;
    rdfs:label "Élément de serrurerie"@fr ;
    hpo:allowedForElementCategory hpo:AutreElementToiture .

#################################################################
# Classification levels
#################################################################

hpo:ClassificationFaible a hpo:ClassificationLevel ;
    rdfs:label "Faible"@fr .

hpo:ClassificationModere a hpo:ClassificationLevel ;
    rdfs:label "Modéré"@fr .

hpo:ClassificationEleve a hpo:ClassificationLevel ;
    rdfs:label "Élevé"@fr .

hpo:ClassificationTresEleve a hpo:ClassificationLevel ;
    rdfs:label "Très élevé"@fr .@prefix hpo: <https://example.org/heritage-pathology-ontology#> .
