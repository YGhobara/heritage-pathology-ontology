#################################################################
# Sample observations
#################################################################

hpo:ObservationExample001 a hpo:Observation ;
    hpo:hasVisibilityContext hpo:Interieur ;
    hpo:hasElementCategory hpo:ElementAcces ;
    hpo:hasElementFunction hpo:ElementDeBaieInterieur ;
    hpo:hasMaterial hpo:Pierre ;
    hpo:concernsComponent hpo:Porte ;
